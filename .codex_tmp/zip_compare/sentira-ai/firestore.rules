rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'admin';
    }

    function isOfficer() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'officer';
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && incoming().role == 'citizen';
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && (
        // Citizens can't change their own role
        (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role'])) ||
        isAdmin()
      );
    }

    // --- Complaints ---
    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(complaintId) && incoming().citizenId == request.auth.uid && incoming().status == 'submitted';
      allow update: if isSignedIn() && (
        // Citizen updates (e.g. upvoting/metadata if allowed, but strictly limited)
        (isOwner(existing().citizenId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'updatedAt'])) ||
        // Admin or Officer updates
        (isAdmin() || isOfficer())
      );
      allow delete: if isAdmin();
    }

    // --- Departments ---
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Subcollections ---
    match /complaints/{complaintId}/votes/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
